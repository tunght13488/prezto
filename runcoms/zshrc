function xdebug_activate() {
  if (( $+commands[$1] )); then
    if [[ -f "$2.deactivated" ]]; then
      sudo mv "$2.deactivated" "$2"
      [[ "$OSTYPE" == linux* ]] && sudo systemctl restart "$3"
      [[ "$OSTYPE" == darwin* ]] && brew services restart "$3"
    fi
  fi
}
function xdebug_deactivate() {
  if (( $+commands[$1] )); then
    if [[ -f "$2" ]]; then
      sudo mv "$2" "$2.deactivated"
      [[ "$OSTYPE" == linux* ]] && sudo systemctl restart "$3"
      [[ "$OSTYPE" == darwin* ]] && brew services restart "$3"
    fi
  fi
}
function xdebug () {
  local OSNAME=$(lsb_release -si)
  case $1 in
    on)
      if [[ "$OSTYPE" == linux* ]]; then
        if [[ "$OSNAME" == Ubuntu ]]; then
          xdebug_activate "php8.0" "/etc/php/8.0/mods-available/xdebug.ini" "php8.0-fpm.service"
          xdebug_activate "php8.1" "/etc/php/8.1/mods-available/xdebug.ini" "php8.1-fpm.service"
        else
          xdebug_activate "php70" "/etc/php70/conf.d/xdebug.ini" "php70-fpm"
          xdebug_activate "php71" "/etc/php71/conf.d/xdebug.ini" "php71-fpm"
          xdebug_activate "php72" "/etc/php72/conf.d/xdebug.ini" "php72-fpm"
          xdebug_activate "php73" "/etc/php73/conf.d/xdebug.ini" "php73-fpm"
          xdebug_activate "php74" "/etc/php74/conf.d/xdebug.ini" "php74-fpm"
          xdebug_activate "php7" "/etc/php7/conf.d/xdebug.ini" "php-fpm7"
          xdebug_activate "php80" "/etc/php80/conf.d/xdebug.ini" "php80-fpm"
          xdebug_activate "php-legacy" "/etc/php-legacy/conf.d/xdebug.ini" "php-legacy-fpm"
          xdebug_activate "php" "/etc/php/conf.d/xdebug.ini" "php-fpm"
        fi
      fi
      if [[ "$OSTYPE" == darwin* ]]; then
        xdebug_activate "php" "/usr/local/etc/php/7.2/conf.d/ext-xdebug.ini" "php@7.2"
      fi
      export XDEBUG_CONFIG="idekey=PHPSTORM"
    ;;
    off)
      if [[ "$OSTYPE" == linux* ]]; then
        if [[ "$OSNAME" == Ubuntu ]]; then
          xdebug_deactivate "php8.0" "/etc/php/8.0/mods-available/xdebug.ini" "php8.0-fpm.service"
          xdebug_deactivate "php8.1" "/etc/php/8.1/mods-available/xdebug.ini" "php8.1-fpm.service"
        else
          xdebug_deactivate "php70" "/etc/php70/conf.d/xdebug.ini" "php70-fpm"
          xdebug_deactivate "php71" "/etc/php71/conf.d/xdebug.ini" "php71-fpm"
          xdebug_deactivate "php72" "/etc/php72/conf.d/xdebug.ini" "php72-fpm"
          xdebug_deactivate "php73" "/etc/php73/conf.d/xdebug.ini" "php73-fpm"
          xdebug_deactivate "php74" "/etc/php74/conf.d/xdebug.ini" "php74-fpm"
          xdebug_deactivate "php7" "/etc/php7/conf.d/xdebug.ini" "php-fpm7"
          xdebug_deactivate "php80" "/etc/php80/conf.d/xdebug.ini" "php80-fpm"
          xdebug_deactivate "php-legacy" "/etc/php-legacy/conf.d/xdebug.ini" "php-legacy-fpm"
          xdebug_deactivate "php" "/etc/php/conf.d/xdebug.ini" "php-fpm"
        fi
      fi
      if [[ "$OSTYPE" == darwin* ]]; then
        xdebug_deactivate "php" "/usr/local/etc/php/7.2/conf.d/ext-xdebug.ini" "php@7.2"
      fi
      unset XDEBUG_CONFIG
    ;;
    *)
      echo "Usage: xdebug on|off"
    ;;
  esac
}
function phps_on() {
  local OSNAME=$(lsb_release -si)
  if (( $+commands[$1] )); then
    if [[ "$OSNAME" == Ubuntu ]]; then
      sudo update-alternatives --set php "/usr/bin/$1"
    else
      ln -sf "/usr/bin/$1" "$HOME/bin/php" && rehash
    fi
  fi
}
function phps_off() {
  local OSNAME=$(lsb_release -si)
  if [[ "$OSNAME" == Ubuntu ]]; then
    sudo update-alternatives --auto php
  else
    [ -f "$HOME/bin/php" ] && unlink "$HOME/bin/php" && rehash
  fi
}
function phps () {
  local OSNAME=$(lsb_release -si)
  case $1 in
    70)
      phps_on "php70"
    ;;
    71)
      phps_on "php71"
    ;;
    72)
      phps_on "php72"
    ;;
    80)
      if [[ "$OSNAME" == Ubuntu ]]; then
        phps_on "php8.0"
      else
        phps_on "php80"
      fi
    ;;
    81)
      if [[ "$OSNAME" == Ubuntu ]]; then
        phps_on "php8.1"
      else
        phps_on "php-legacy"
      fi
    ;;
    off)
      phps_off
    ;;
    *)
      echo "Alias php70/php71/php72/php80/php-legacy to php"
      echo "Usage: phps 70|71|72|80|81|off"
    ;;
  esac
}
