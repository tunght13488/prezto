function warm_urls() {
  echo ' Connect  | Transfer |  Total   | Status  | URL'
  echo '----------|----------|----------|---------|----'
  cat "$1" | while read line; do
    curl -so /dev/null -w " %{time_connect} | %{time_starttransfer} | %{time_total} |   %{http_code}   " $line
    echo "| $line"
  done
}
